VM_SMART_PROVIDER=ollama
OLLAMA_CLOUD_URL=https://your-ollama-cloud-endpoint.example
OLLAMA_CLOUD_API_KEY=replace_with_your_key
OLLAMA_CLOUD_MODEL=llama3.1:8b

# Use "ollama" for /api/chat, or "openai" for /v1/chat/completions compatible endpoints.
OLLAMA_CLOUD_MODE=ollama
OLLAMA_CLOUD_TIMEOUT=35

# Paddle checkout (set these to enable payment buttons)
PADDLE_ENV=sandbox
PADDLE_CLIENT_TOKEN=replace_with_paddle_client_token
